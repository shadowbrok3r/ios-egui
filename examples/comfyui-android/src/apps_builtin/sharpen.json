{
  "id": "sharpen",
  "name": "Sharpen",
  "group": "Finish",
  "description": "Unsharp mask over the finished image.",
  "version": 1,
  "requires": [{ "class": "ImageSharpen", "pack": "core" }],
  "knobs": [
    {
      "id": "alpha",
      "label": "Amount",
      "ty": { "Float": { "min": 0.0, "max": 5.0, "step": 0.05 } },
      "default": 0.6
    },
    {
      "id": "sharpen_radius",
      "label": "Radius",
      "ty": { "Int": { "min": 1, "max": 31, "step": 2 } },
      "default": 3,
      "advanced": true
    },
    {
      "id": "sigma",
      "label": "Sigma",
      "ty": { "Float": { "min": 0.1, "max": 10.0, "step": 0.1 } },
      "default": 1.0,
      "advanced": true
    }
  ],
  "nodes": [
    {
      "id": "sharp",
      "class": "ImageSharpen",
      "inputs": {
        "image": "$image",
        "sharpen_radius": "$knob:sharpen_radius",
        "sigma": "$knob:sigma",
        "alpha": "$knob:alpha"
      }
    }
  ],
  "output": { "node": "sharp", "slot": 0 }
}
