{
  "id": "hires.fix",
  "name": "Hi-res fix",
  "group": "Hi-res",
  "description": "Upscales the latent and re-samples it, then decodes. Runs before any image step.",
  "version": 1,
  "requires": [
    { "class": "LatentUpscaleBy", "pack": "core" },
    { "class": "KSampler", "pack": "core" },
    { "class": "VAEDecode", "pack": "core" }
  ],
  "overrides": [
    { "param": "width", "op": { "DivideByKnob": "scale_by" }, "round_to": 64, "min": 384.0 },
    { "param": "height", "op": { "DivideByKnob": "scale_by" }, "round_to": 64, "min": 384.0 }
  ],
  "knobs": [
    {
      "id": "scale_by",
      "label": "Scale",
      "ty": { "Float": { "min": 1.0, "max": 3.0, "step": 0.05 } },
      "default": 1.5
    },
    {
      "id": "denoise",
      "label": "Strength",
      "ty": { "Float": { "min": 0.1, "max": 1.0, "step": 0.05 } },
      "default": 0.5,
      "tooltip": "How much the second pass is allowed to change. Above ~0.7 it redraws."
    },
    {
      "id": "steps",
      "label": "Steps",
      "ty": { "Int": { "min": 1, "max": 100, "step": 1 } },
      "default": 14,
      "advanced": true
    },
    {
      "id": "upscale_method",
      "label": "Latent method",
      "ty": { "Enum": { "class": "LatentUpscaleBy", "input": "upscale_method" } },
      "default": "bislerp",
      "advanced": true
    }
  ],
  "nodes": [
    {
      "id": "lat",
      "class": "LatentUpscaleBy",
      "inputs": {
        "samples": "$latent",
        "upscale_method": "$knob:upscale_method",
        "scale_by": "$knob:scale_by"
      }
    },
    {
      "id": "ks",
      "class": "KSampler",
      "inputs": {
        "model": "$model",
        "positive": "$positive",
        "negative": "$negative",
        "latent_image": "$node:lat:0",
        "seed": "$seed+1",
        "steps": "$knob:steps",
        "cfg": "$param:cfg",
        "sampler_name": "$param:sampler",
        "scheduler": "$param:scheduler",
        "denoise": "$knob:denoise"
      }
    },
    {
      "id": "dec",
      "class": "VAEDecode",
      "inputs": { "samples": "$node:ks:0", "vae": "$vae" }
    }
  ],
  "output": { "node": "dec", "slot": 0 }
}
