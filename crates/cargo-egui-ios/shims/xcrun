#!/usr/bin/env bash
# Minimal `xcrun` shim for Linux hosts: `cc-rs` and some crates invoke
# `xcrun --show-sdk-path` when targeting Apple platforms. Set `SDKROOT` to your
# iOS SDK root (from xtool) and this shim is prepended to PATH by `cargo egui-ios`.
set -euo pipefail

sdk=""
if [[ "${1:-}" == "--sdk" ]]; then
  sdk="${2:-}"
  shift 2
fi

case "${1:-}" in
  --show-sdk-path|-show-sdk-path)
    echo "${SDKROOT:?SDKROOT must be set}"
    exit 0
    ;;
  simctl)
    # No Apple simulator on Linux. Pretend success.
    exit 0
    ;;
  *)
    echo "xcrun shim: unsupported args: sdk='$sdk' argv='$*'" >&2
    exit 2
    ;;
esac
